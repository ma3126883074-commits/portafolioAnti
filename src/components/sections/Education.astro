---
import SectionTitle from '../ui/SectionTitle.astro';
import Card from '../ui/Card.astro';

const education = [
  {
    degree: 'Ingeniería en Sistemas Computacionales',
    institution: 'Universidad Nacional',
    period: '2014 - 2018',
    description: 'Especialización en Ingeniería de Software. Proyecto de grado enfocado en sistemas distribuidos.',
  }
];

const certifications = [
  {
    name: 'AWS Certified Solutions Architect',
    issuer: 'Amazon Web Services',
    date: '2022'
  },
  {
    name: 'Meta Front-End Developer Professional Certificate',
    issuer: 'Coursera / Meta',
    date: '2021'
  }
];
---

<section id="formacion" class="py-20 bg-white dark:bg-dark-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionTitle title="Formación y Certificaciones" />
    
    <div class="mt-12 grid md:grid-cols-2 gap-12">
      <!-- Educación -->
      <div>
        <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-6 flex items-center">
          <svg class="w-6 h-6 mr-2 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path d="M12 14l9-5-9-5-9 5 9 5z" />
            <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
          </svg>
          Educación Académica
        </h3>
        <div class="space-y-6">
          {education.map(ed => (
            <Card className="p-6">
              <h4 class="text-lg font-bold text-slate-900 dark:text-white">{ed.degree}</h4>
              <div class="flex justify-between items-center mt-2 mb-4">
                <span class="text-primary-600 dark:text-primary-400 font-medium">{ed.institution}</span>
                <span class="text-sm text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded">{ed.period}</span>
              </div>
              <p class="text-slate-600 dark:text-slate-400 text-sm">{ed.description}</p>
            </Card>
          ))}
        </div>
      </div>

      <!-- Certificaciones -->
      <div>
        <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-6 flex items-center">
          <svg class="w-6 h-6 mr-2 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
          Certificaciones
        </h3>
        <div class="space-y-4">
          {certifications.map(cert => (
            <div class="bg-slate-50 dark:bg-dark-800 border border-slate-200 dark:border-slate-700 rounded-xl p-5 flex items-start justify-between">
              <div>
                <h4 class="font-bold text-slate-900 dark:text-white">{cert.name}</h4>
                <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">{cert.issuer}</p>
              </div>
              <span class="text-xs font-bold text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/20 px-2 py-1 rounded">
                {cert.date}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
