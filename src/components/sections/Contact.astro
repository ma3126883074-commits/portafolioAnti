---
import SectionTitle from '../ui/SectionTitle.astro';
import Button from '../ui/Button.astro';
---

<section id="contacto" class="py-20 bg-slate-50 dark:bg-dark-800">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionTitle title="Ponte en Contacto" subtitle="¿Tienes una propuesta o simplemente quieres saludar? ¡Escríbeme!" />
    
    <div class="mt-12 bg-white dark:bg-dark-900 rounded-2xl shadow-xl border border-slate-200 dark:border-slate-700 overflow-hidden">
      <div class="grid md:grid-cols-5 h-full">
        <div class="md:col-span-2 bg-primary-600 dark:bg-primary-700 p-8 text-white flex flex-col justify-between">
          <div>
            <h3 class="text-2xl font-bold mb-4">Información de Contacto</h3>
            <p class="text-primary-100 mb-8">
              Llenar el formulario y te responderé en menos de 24 horas.
            </p>
            
            <div class="space-y-6">
              <div class="flex items-center">
                <svg class="w-6 h-6 text-primary-200 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span>tu.email@ejemplo.com</span>
              </div>
              <div class="flex items-center">
                <svg class="w-6 h-6 text-primary-200 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>Tu Ciudad, País</span>
              </div>
            </div>
          </div>
          
          <div class="mt-12 flex space-x-4">
            <!-- Redes sociales iconos -->
            <a href="#" class="w-10 h-10 rounded-full bg-primary-500 hover:bg-white hover:text-primary-600 flex items-center justify-center transition-colors">
              <span class="sr-only">GitHub</span>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href="#" class="w-10 h-10 rounded-full bg-primary-500 hover:bg-white hover:text-primary-600 flex items-center justify-center transition-colors">
              <span class="sr-only">LinkedIn</span>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
              </svg>
            </a>
          </div>
        </div>
        
        <div class="md:col-span-3 p-8">
          <form class="space-y-6" onsubmit="event.preventDefault(); alert('Funcionalidad de formulario a implementar (ej. con Formspree)');">
            <div>
              <label for="name" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Nombre</label>
              <input type="text" id="name" name="name" required class="mt-1 block w-full rounded-md border border-slate-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-dark-800 text-slate-900 dark:text-white focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition-colors" placeholder="Tu nombre">
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Correo Electrónico</label>
              <input type="email" id="email" name="email" required class="mt-1 block w-full rounded-md border border-slate-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-dark-800 text-slate-900 dark:text-white focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition-colors" placeholder="tucorreo@ejemplo.com">
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Mensaje</label>
              <textarea id="message" name="message" rows="4" required class="mt-1 block w-full rounded-md border border-slate-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-dark-800 text-slate-900 dark:text-white focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition-colors" placeholder="¿En qué te puedo ayudar?"></textarea>
            </div>
            
            <Button type="submit" variant="primary" className="w-full">
              Enviar Mensaje
            </Button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
