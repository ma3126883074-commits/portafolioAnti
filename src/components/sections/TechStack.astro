---
import SectionTitle from '../ui/SectionTitle.astro';

const technologies = [
  { name: 'HTML5', category: 'Frontend' },
  { name: 'CSS3', category: 'Frontend' },
  { name: 'JavaScript', category: 'Frontend' },
  { name: 'TypeScript', category: 'Frontend' },
  { name: 'React', category: 'Frontend' },
  { name: 'Astro', category: 'Frontend' },
  { name: 'Tailwind CSS', category: 'Frontend' },
  { name: 'Node.js', category: 'Backend' },
  { name: 'Express', category: 'Backend' },
  { name: 'PostgreSQL', category: 'Database' },
  { name: 'MongoDB', category: 'Database' },
  { name: 'Git', category: 'Tools' },
  { name: 'Docker', category: 'Tools' },
  { name: 'Figma', category: 'Design' },
];
---

<section id="tecnologias" class="py-20 bg-slate-50 dark:bg-dark-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionTitle title="Tech Stack" subtitle="Las tecnologías y herramientas con las que trabajo en el día a día." />
    
    <div class="mt-12 flex flex-wrap justify-center gap-4">
      {technologies.map(tech => (
        <div class="group px-6 py-4 bg-white dark:bg-dark-900 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-md transition-all hover:border-primary-500 cursor-default">
          <p class="font-semibold text-slate-800 dark:text-slate-200 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
            {tech.name}
          </p>
          <span class="text-xs text-slate-500 dark:text-slate-400 mt-1 block">
            {tech.category}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
