---
interface Props {
  title: string;
  subtitle?: string;
  alignment?: 'left' | 'center';
}

const { title, subtitle, alignment = 'center' } = Astro.props;
---

<div class={`mb-12 ${alignment === 'center' ? 'text-center' : 'text-left'}`}>
  <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 dark:text-white mb-4">
    {title}
    <span class="block w-16 h-1 bg-primary-600 mt-4 rounded-full" class:list={[{ 'mx-auto': alignment === 'center' }]} />
  </h2>
  {subtitle && <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl" class:list={[{ 'mx-auto': alignment === 'center' }]}>{subtitle}</p>}
</div>
