---
interface Props {
  className?: string;
  hoverEffect?: boolean;
}

const { className = '', hoverEffect = true } = Astro.props;
---

<div 
  class={`bg-white dark:bg-dark-800 rounded-2xl border border-slate-200 dark:border-slate-700/50 overflow-hidden transition-all duration-300 ${hoverEffect ? 'hover:shadow-xl hover:shadow-slate-200/50 dark:hover:shadow-black/50 hover:-translate-y-1' : ''} ${className}`}
>
  <slot />
</div>
